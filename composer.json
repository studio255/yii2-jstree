{
    "name": "studio255/yii2-jstree",
    "description": "jsTree is jquery plugin, that provides interactive trees",
    "type": "yii2-extension",
    "keywords": ["yii2","extension"],
    "license": "MIT",
    "authors": [
        {
            "name": "Studio255 Karlsruhe",
            "email": "mail@studio255.de"
        }
    ],
    "require": {
        "php": ">=8.2",
        "yiisoft/yii2": "^2.0.55",
        "vakata/jstree" : "3.3"
    },
    "config": {
        "process-timeout": 1800,
        "fxp-asset": {
            "enabled": false
        },
        "asset-installer-paths": {
            "npm-asset-library": "vendor/npm",
            "bower-asset-library": "vendor/bower-asset"
        }
    },
    "autoload": {
        "psr-4": {
            "studio255\\jstree\\": ""
        }
    }
}
